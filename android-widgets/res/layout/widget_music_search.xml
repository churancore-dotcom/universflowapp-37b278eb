<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_search_bar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_search_background">

    <ImageView
        android:id="@+id/widget_search_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_search"
        android:contentDescription="Search icon"
        android:layout_marginEnd="10dp" />

    <TextView
        android:id="@+id/widget_search_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Search songs, artists..."
        android:textColor="#8E8E93"
        android:textSize="16sp"
        android:fontFamily="sans-serif" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_mic"
        android:contentDescription="Voice search" />

</LinearLayout>
